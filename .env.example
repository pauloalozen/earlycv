# Shared app endpoints
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WEB_PORT=3000
API_PORT=4000

# Web-only public env exposure
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Shared database
DATABASE_URL=postgresql://earlycv:earlycv@localhost:5432/earlycv
POSTGRES_DB=earlycv
POSTGRES_USER=earlycv
POSTGRES_PASSWORD=earlycv
POSTGRES_PORT=5432

# Shared Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# Shared object storage (S3-compatible / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=earlycv-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
MINIO_CONSOLE_PORT=9001

# AI provider example: OpenAI-specific variables
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
