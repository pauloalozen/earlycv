# Shared app endpoints
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
API_HOST=0.0.0.0
WEB_PORT=3000
API_PORT=4000
# Jobs portal ghost mode (admin/superadmin only)
JOBS_GHOST_MODE=false
FRONTEND_URL=http://localhost:3000

# CORS: origens adicionais separadas por vírgula (ex: produção)
# CORS_ORIGINS=https://app.seudominio.com.br

# Web-only public env exposure
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public jobs portal ghost mode toggle
NEXT_PUBLIC_JOBS_GHOST_MODE=false

# Shared database
DATABASE_URL=postgresql://earlycv:earlycv@localhost:5432/earlycv
DATABASE_TEST_URL=postgresql://earlycv:earlycv@localhost:5432/earlycv_test
POSTGRES_DB=earlycv
POSTGRES_TEST_DB=earlycv_test
POSTGRES_USER=earlycv
POSTGRES_PASSWORD=earlycv
POSTGRES_PORT=5432

# Shared Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# API auth and OAuth
JWT_ACCESS_SECRET=replace-me
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=replace-me
JWT_REFRESH_TTL=2592000
GOOGLE_CLIENT_ID=replace-me
GOOGLE_CLIENT_SECRET=replace-me
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
LINKEDIN_CLIENT_ID=replace-me
LINKEDIN_CLIENT_SECRET=replace-me
LINKEDIN_CALLBACK_URL=http://localhost:4000/api/auth/linkedin/callback

# Shared object storage (S3-compatible / MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=earlycv-local
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
MINIO_CONSOLE_PORT=9001
# S3_PUBLIC_BASE_URL: só usar em buckets EXCLUSIVAMENTE de assets públicos (ex: logos).
# NUNCA definir num bucket que contém CVs ou arquivos de usuários.
# S3_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# AI supplier+model selector — uma variável só por etapa, no formato
# "<supplier>|<model>" (fornecedor: openai | xai | anthropic | gemini | kimi | glm | deepseek | openrouter).
# Todos os supliers usam o SDK "openai" (endpoint OpenAI-compatible de cada provedor) —
# ver apps/api/src/common/ai-client-factory.ts.
#
# AI_SUPPLIER é o fallback global. Cada etapa pode ter seu próprio override via
# AI_SUPPLIER_<OPERACAO> (ANALYSIS | CV_GENERATION | JOB_CANONICALIZATION | MASTERCV | INTERVIEW_PREP),
# permitindo por exemplo usar um modelo barato na análise/extração e um modelo mais forte na
# geração do texto final do CV. Sem override, todas as etapas usam o AI_SUPPLIER global.
#
# Nomes de modelo para openrouter são prefixados pelo provedor de origem
# (ex: "anthropic/claude-sonnet-4.6") — não use o nome "cru" do provedor.
AI_SUPPLIER=openai|gpt-4.1-mini
# AI_SUPPLIER_ANALYSIS=deepseek|deepseek-v4-flash
# AI_SUPPLIER_CV_GENERATION=openrouter|anthropic/claude-sonnet-4.6
# AI_SUPPLIER_JOB_CANONICALIZATION=deepseek|deepseek-v4-flash
# AI_SUPPLIER_MASTERCV=openai|gpt-4o-mini
# AI_SUPPLIER_INTERVIEW_PREP=openai|gpt-5.4-mini

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# xAI (Grok) — ativar com AI_SUPPLIER=xai|grok-3-mini (ou AI_SUPPLIER_<OPERACAO>=xai|...)
# XAI_API_KEY=your-xai-api-key
# XAI_BASE_URL=https://api.x.ai/v1

# Anthropic (Claude) — ativar com AI_SUPPLIER=anthropic|claude-sonnet-4-6 (ou AI_SUPPLIER_<OPERACAO>=anthropic|...)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Google Gemini — ativar com AI_SUPPLIER=gemini|gemini-2.5-flash (ou AI_SUPPLIER_<OPERACAO>=gemini|...)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Kimi / Moonshot AI — ativar com AI_SUPPLIER=kimi|kimi-k2.6 (ou AI_SUPPLIER_<OPERACAO>=kimi|...)
# MOONSHOT_API_KEY=your-moonshot-api-key
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# GLM / Z.ai (Zhipu AI) — ativar com AI_SUPPLIER=glm|glm-5.2 (ou AI_SUPPLIER_<OPERACAO>=glm|...)
# ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# DeepSeek — ativar com AI_SUPPLIER=deepseek|deepseek-v4-flash (ou AI_SUPPLIER_<OPERACAO>=deepseek|...)
# DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter (agregador multi-modelo) — ativar com AI_SUPPLIER=openrouter|openai/gpt-4o-mini (ou AI_SUPPLIER_<OPERACAO>=openrouter|...)
# OPENROUTER_API_KEY=your-openrouter-api-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://earlycv.com.br
# OPENROUTER_SITE_NAME=EarlyCV

# Os nomes de modelo acima refletem o catálogo de cada provedor em jul/2026 —
# conferir a documentação oficial antes de ativar em produção, pois mudam com frequência.

SKIP_AI=true

# Plans — prices in cents, quantities, and pre-configured MP links
PRICE_PLAN_STARTER=1190
PRICE_PLAN_PRO=2990
PRICE_PLAN_TURBO=5990
QNT_CV_PLAN_STARTER=3
QNT_CV_PLAN_PRO=3
QNT_CV_PLAN_TURBO=10
QNT_AN_PLAN_FREE=3
QNT_AN_PLAN_STARTER=6
QNT_AN_PLAN_PRO=9
QNT_AN_PLAN_TURBO=30
QNT_AN_CREDIT_PLAN_STARTER=6
QNT_AN_CREDIT_PLAN_PRO=9
QNT_AN_CREDIT_PLAN_TURBO=30
# Não usar LINK_PLAN, ativa checkou direto e desliga rastreabilidade interna.
#LINK_PLAN_STARTER=https://mpago.li/replace-me
#LINK_PLAN_PRO=https://mpago.li/replace-me
#LINK_PLAN_TURBO=https://mpago.li/replace-me
# Não usar LINK_PLAN, ativa checkou direto e desliga rastreabilidade interna.

# Payment provider selection (mercadopago or stripe)
PAYMENT_PROVIDER=mercadopago

# Mercado Pago
# MERCADOPAGO_MODE=production  ← descomente para usar token/link de produção localmente
MERCADOPAGO_ACCESS_TOKEN=replace-me
MERCADOPAGO_ACCESS_TOKEN_TEST=replace-me
MERCADOPAGO_PRO_ACCESS_TOKEN=replace-me
MERCADOPAGO_PRO_ACCESS_TOKEN_TEST=replace-me
MERCADOPAGO_PRO_WEBHOOK_SECRET=replace-me
NEXT_PUBLIC_MERCADOPAGO_PRO_PUBLIC_KEY=replace-me
MERCADOPAGO_BRICK_ACCESS_TOKEN=replace-me
MERCADOPAGO_BRICK_ACCESS_TOKEN_TEST=replace-me
MERCADOPAGO_BRICK_WEBHOOK_SECRET=replace-me
NEXT_PUBLIC_MERCADOPAGO_BRICK_PUBLIC_KEY=replace-me
MERCADOPAGO_WEBHOOK_SECRET=replace-me

# Checkout rollout controls
PAYMENT_CHECKOUT_MODE=pro

# Payment recovery controls
ADMIN_PAYMENT_RECOVERY_ENABLED=false
PAYMENT_RECOVERY_EMAIL_ENABLED=false
PAYMENT_RECOVERY_EMAIL_DRY_RUN=true
PAYMENT_RECOVERY_EMAIL_ALLOWLIST=
PAYMENT_RECOVERY_TOKEN_TTL_DAYS=7
PAYMENT_RECOVERY_PUBLIC_RATE_LIMIT_PER_MINUTE=30
PAYMENT_RECOVERY_TOKEN_SINGLE_USE=true

# Stripe
STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me

# Ambiente de execução: use apenas "development", "staging" ou "production"
# Quando != "production", emails são sempre mockados no console (mesmo com RESEND_API_KEY definido)
APP_ENV=development

# Ambiente exposto ao frontend para analytics (use o mesmo valor do APP_ENV)
NEXT_PUBLIC_APP_ENV=development

# Email (produção)
# Requer APP_ENV=production para enviar emails reais via Resend
RESEND_API_KEY=replace-me
EMAIL_FROM=EarlyCV <noreply@seudominio.com.br>

# PostHog Analytics
POSTHOG_API_KEY=replace-me
POSTHOG_PROJECT_ID=replace-me
NEXT_PUBLIC_POSTHOG_KEY=replace-me
NEXT_PUBLIC_POSTHOG_API_HOST=https://c.earlycv.com.br
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com
NEXT_PUBLIC_ANALYTICS_CONSENT_ENABLED=true
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FGMKXL50XR

# GA4 Measurement Protocol (backend purchase sync)
GA4_ENABLED=false
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=replace-me
GA4_DEBUG_MODE=false

# Variante de LandingPage
NEXT_PUBLIC_LANDING_VARIANT=A
