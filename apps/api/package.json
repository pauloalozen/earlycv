{
  "name": "@earlycv/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:shared": "npm run build --workspace @earlycv/config --workspace @earlycv/database --workspace @earlycv/queue --workspace @earlycv/storage --workspace @earlycv/ai",
    "dev": "NODE_OPTIONS='--conditions=development' nest start --watch",
    "build": "NODE_OPTIONS='--conditions=development' nest build",
    "prestart": "npm run build:shared",
    "start": "node dist/main.js",
    "lint": "biome lint --config-path ../../biome.json .",
    "check": "NODE_OPTIONS='--conditions=development' biome check --config-path ../../biome.json .",
    "test": "NODE_OPTIONS='--conditions=development' tsx --test src/**/*.spec.ts src/**/*.e2e-spec.ts"
  },
  "dependencies": {
    "@earlycv/ai": "0.1.0",
    "@earlycv/config": "0.1.0",
    "@earlycv/database": "0.1.0",
    "@earlycv/queue": "0.1.0",
    "@earlycv/storage": "0.1.0",
    "@nestjs/common": "^11.1.9",
    "@nestjs/core": "^11.1.9",
    "@nestjs/platform-express": "^11.1.9",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.9",
    "@types/node": "^20",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
