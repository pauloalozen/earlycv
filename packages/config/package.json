{
  "name": "@earlycv/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "biome",
    "dist",
    "src",
    "typescript"
  ],
  "exports": {
    "./biome/base": "./biome/base.json",
    "./analytics-env": {
      "development": "./src/analytics-env.ts",
      "types": "./src/analytics-env.ts",
      "default": "./dist/analytics-env.js"
    },
    "./env": {
      "development": "./src/env.ts",
      "types": "./src/env.ts",
      "default": "./dist/env.js"
    },
    "./typescript/base": "./typescript/base.json",
    "./typescript/nest": "./typescript/nest.json",
    "./typescript/nextjs": "./typescript/nextjs.json"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "lint": "sh -c 'biome lint --config-path \"$(realpath ../../biome.json)\" src'",
    "check": "sh -c 'biome check --config-path \"$(realpath ../../biome.json)\" src && tsc -p tsconfig.json --noEmit'",
    "test": "tsx --test src/**/*.spec.ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
