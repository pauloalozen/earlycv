{
  "name": "@earlycv/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "prisma"
  ],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "development": "./src/client.ts",
      "types": "./src/client.ts",
      "default": "./dist/client.js"
    },
    "./schema": "./prisma/schema.prisma"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "generate": "prisma generate --schema prisma/schema.prisma",
    "migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "lint": "biome lint --config-path ../../biome.json .",
    "check": "biome check --config-path ../../biome.json . && tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/**/*.spec.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0"
  }
}
