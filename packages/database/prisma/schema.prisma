generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlanType {
  free
}

enum UserStatus {
  active
  pending
  suspended
  deleted
}

enum RemotePreference {
  remote
  hybrid
  onsite
  flexible
}

enum AuthProvider {
  credentials
  google
  linkedin
}

enum ResumeStatus {
  draft
  uploaded
  reviewed
  failed
}

enum JobSourceType {
  workday
  greenhouse
  lever
  gupy
  kenoby
  successfactors
  custom_html
  custom_api
}

enum CrawlStrategy {
  html
  api
  feed
}

enum JobStatus {
  active
  inactive
  removed
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String?
  name            String
  planType        UserPlanType   @default(free)
  status          UserStatus     @default(pending)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  profile         UserProfile?
  authAccounts    AuthAccount[]
  refreshTokens   RefreshToken[]
  resumes         Resume[]
}

model UserProfile {
  id                    String            @id @default(cuid())
  userId                String            @unique
  headline              String?
  currentTitle          String?
  summary               String?
  yearsExperience       Int?
  city                  String?
  state                 String?
  country               String?
  remotePreference      RemotePreference?
  relocationPreference  Boolean?
  targetSalaryMin       Int?
  targetSalaryMax       Int?
  preferredLanguage     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                    String        @id @default(cuid())
  userId                String
  provider              AuthProvider
  providerAccountId     String
  providerEmail         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  tokenHash  String
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Resume {
  id             String       @id @default(cuid())
  userId         String
  title          String
  sourceFileName String?
  sourceFileUrl  String?
  sourceFileType String?
  rawText        String?
  parsedJson     Json?
  normalizedJson Json?
  status            ResumeStatus @default(draft)
  isPrimary         Boolean      @default(false)
  primaryResumeSlot Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isPrimary])
  @@unique([userId, primaryResumeSlot])
}

model Company {
  id             String      @id @default(cuid())
  name           String
  normalizedName String      @unique
  websiteUrl     String?
  careersUrl     String?
  linkedinUrl    String?
  industry       String?
  country        String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  jobSources     JobSource[]
  jobs           Job[]
}

model JobSource {
  id                   String         @id @default(cuid())
  companyId            String
  sourceName           String
  sourceType           JobSourceType
  sourceUrl            String
  parserKey            String
  crawlStrategy        CrawlStrategy
  isActive             Boolean        @default(true)
  checkIntervalMinutes Int
  lastCheckedAt        DateTime?
  lastSuccessAt        DateTime?
  lastErrorAt          DateTime?
  lastErrorMessage     String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  company              Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs                 Job[]

  @@unique([companyId, sourceUrl])
  @@index([companyId])
}

model Job {
  id                String     @id @default(cuid())
  companyId         String
  jobSourceId       String
  externalJobId     String?
  sourceJobUrl      String
  canonicalKey      String     @unique
  title             String
  normalizedTitle   String
  descriptionRaw    String
  descriptionClean  String
  locationText      String
  city              String?
  state             String?
  country           String?
  workModel         String?
  seniorityLevel    String?
  employmentType    String?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?
  publishedAtSource DateTime?
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  status            JobStatus  @default(active)
  metadataJson      Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobSource         JobSource  @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([jobSourceId])
  @@index([firstSeenAt])
}
