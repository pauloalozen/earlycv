generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlanType {
  free
  starter
  pro
  unlimited
  turbo
}

enum UserStatus {
  active
  pending
  suspended
  deleted
}

enum InternalRole {
  none
  admin
  superadmin
}

enum RemotePreference {
  remote
  hybrid
  onsite
  flexible
}

enum AuthProvider {
  credentials
  google
  linkedin
}

enum ResumeStatus {
  draft
  uploaded
  reviewed
  failed
}

enum ResumeKind {
  master
  adapted
}

enum JobSourceType {
  workday
  greenhouse
  lever
  gupy
  kenoby
  successfactors
  custom_html
  custom_api
}

enum CrawlStrategy {
  html
  api
  feed
}

enum JobStatus {
  active
  inactive
  removed
}

enum IngestionRunStatus {
  running
  completed
  failed
}

enum AffiliatePartnerStatus {
  draft
  active
  inactive
}

enum AffiliateCampaignStatus {
  draft
  active
  inactive
}

enum AffiliateCodeStatus {
  draft
  active
  inactive
}

enum AffiliateRewardType {
  percentage
  fixed_amount
}

enum AffiliateCommissionStatus {
  pending
  approved
  paid
  reversed
}

enum CvAdaptationStatus {
  pending
  analyzing
  awaiting_payment
  paid
  delivered
  failed
}

enum PaymentStatus {
  none
  pending
  completed
  failed
  refunded
}

enum PaymentProvider {
  mercadopago
  stripe
}

enum AnalysisCvSourceType {
  text_input
  uploaded_file
  master_resume
}

enum AnalysisConfigValueType {
  boolean
  int
  duration_ms
  percent
  string
  enum
  json
}

enum AnalysisConfigRiskLevel {
  low
  medium
  high
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String?
  name            String
  planType         UserPlanType   @default(free)
  creditsRemaining Int            @default(0)
  analysisCreditsRemaining Int    @default(0)
  planActivatedAt  DateTime?
  planExpiresAt    DateTime?
  status           UserStatus     @default(pending)
  internalRole     InternalRole   @default(none)
  isStaff          Boolean        @default(false)
  emailVerifiedAt  DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  profile          UserProfile?
  authAccounts     AuthAccount[]
  refreshTokens    RefreshToken[]
  emailVerificationChallenges EmailVerificationChallenge[]
  passwordResetTokens         PasswordResetToken[]
  resumes          Resume[]
  cvAdaptations    CvAdaptation[]
  planPurchases    PlanPurchase[]
  dailyAnalysisUsages         UserDailyAnalysisUsage[]
  affiliateAttributions     AffiliateAttribution[]
  affiliateCommissionEvents AffiliateCommissionEvent[]
  analysisSessions          AnalysisSession[]
  analysisRequestFingerprints AnalysisRequestFingerprint[]
  analysisUsageCounters     AnalysisUsageCounter[]
  analysisProtectionEvents  AnalysisProtectionEvent[]
  businessFunnelEvents      BusinessFunnelEvent[]
  analysisCvSnapshots       AnalysisCvSnapshot[]           @relation("AnalysisCvSnapshotOwner")
  claimedAnalysisCvSnapshots AnalysisCvSnapshot[]          @relation("AnalysisCvSnapshotClaimedBy")
}

model UserDailyAnalysisUsage {
  id        String   @id @default(cuid())
  userId    String
  usageDate DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@index([usageDate])
}

model PlanPurchase {
  id               String          @id @default(cuid())
  userId           String
  planType         UserPlanType
  amountInCents    Int
  currency         String          @default("BRL")
  paymentProvider  PaymentProvider
  paymentReference String          @unique
  status           PaymentStatus   @default(none)
  paidAt           DateTime?
  creditsGranted   Int
  analysisCreditsGranted Int       @default(0)
  mpPaymentId          String?
  mpMerchantOrderId    String?
  mpPreferenceId       String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([paymentReference])
  @@index([mpPaymentId])
}

model PaymentAuditLog {
  id                   String   @id @default(cuid())
  provider             String
  eventType            String
  actionTaken          String
  mpPaymentId          String?
  mpMerchantOrderId    String?
  mpPreferenceId       String?
  externalReference    String?
  internalCheckoutId   String?
  internalCheckoutType String?
  mpStatus             String?
  errorMessage         String?
  rawPayload           Json?
  createdAt            DateTime @default(now())

  @@index([mpPaymentId])
  @@index([externalReference])
  @@index([internalCheckoutId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationChallenge {
  id         String   @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, consumedAt, expiresAt])
}

model UserProfile {
  id                    String            @id @default(cuid())
  userId                String            @unique
  headline              String?
  currentTitle          String?
  summary               String?
  yearsExperience       Int?
  city                  String?
  state                 String?
  country               String?
  remotePreference      RemotePreference?
  relocationPreference  Boolean?
  targetSalaryMin       Int?
  targetSalaryMax       Int?
  preferredLanguage     String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                    String        @id @default(cuid())
  userId                String
  provider              AuthProvider
  providerAccountId     String
  providerEmail         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  sessionId  String   @unique
  tokenHash  String
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Resume {
  id                      String           @id @default(cuid())
  userId                  String
  title                   String
  sourceFileName          String?
  sourceFileUrl           String?
  sourceFileType          String?
  rawText                 String?
  parsedJson              Json?
  normalizedJson          Json?
  status                  ResumeStatus     @default(draft)
  kind                    ResumeKind       @default(master)
  isMaster                Boolean          @default(true)
  basedOnResumeId         String?
  templateId              String?
  targetJobId             String?
  targetJobTitle          String?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  user                    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  basedOnResume           Resume?          @relation("ResumeDerivation", fields: [basedOnResumeId], references: [id], onDelete: SetNull)
  derivedResumes          Resume[]         @relation("ResumeDerivation")
  template                ResumeTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  targetJob               Job?             @relation(fields: [targetJobId], references: [id], onDelete: SetNull)
  cvAdaptationsAsMaster   CvAdaptation[]   @relation("CvAdaptationMaster")
  cvAdaptationAsResult    CvAdaptation?    @relation("CvAdaptationResult")

  @@index([userId])
  @@index([basedOnResumeId])
  @@index([templateId])
  @@index([targetJobId])
}

model ResumeTemplate {
  id                String           @id @default(cuid())
  name              String
  slug              String           @unique
  description       String?
  targetRole        String?
  fileUrl           String?
  previewImageUrl   String?
  structureJson     Json?
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  resumes           Resume[]
  cvAdaptations     CvAdaptation[]
}

model Company {
  id             String      @id @default(cuid())
  name           String
  normalizedName String      @unique
  websiteUrl     String?
  careersUrl     String?
  linkedinUrl    String?
  industry       String?
  country        String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  jobSources     JobSource[]
  jobs           Job[]
}

model CvAdaptation {
  id                   String              @id @default(cuid())
  userId               String
  masterResumeId       String
  templateId           String?
  jobDescriptionText   String
  jobTitle             String?
  companyName          String?
  status               CvAdaptationStatus  @default(pending)
  adaptedContentJson   Json?
  previewText          String?
  adaptedResumeId      String?             @unique
  aiAuditJson          Json?
  paymentStatus        PaymentStatus       @default(none)
  paymentProvider      PaymentProvider?
  paymentReference     String?             @unique
  paymentAmountInCents Int?
  paymentCurrency      String?             @default("BRL")
  paidAt               DateTime?
  mpPaymentId          String?
  mpMerchantOrderId    String?
  mpPreferenceId       String?
  failureReason        String?
  analysisCvSnapshotId String?             @unique
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterResume  Resume          @relation("CvAdaptationMaster", fields: [masterResumeId], references: [id], onDelete: Cascade)
  template      ResumeTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  adaptedResume Resume?         @relation("CvAdaptationResult", fields: [adaptedResumeId], references: [id], onDelete: SetNull)
  analysisCvSnapshot AnalysisCvSnapshot? @relation(fields: [analysisCvSnapshotId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([masterResumeId])
  @@index([paymentReference])
  @@index([mpPaymentId])
  @@index([analysisCvSnapshotId])
}

model AnalysisCvSnapshot {
  id                    String               @id @default(cuid())
  userId                String?
  guestSessionHash      String?
  sourceType            AnalysisCvSourceType
  textStorageKey        String
  textSha256            String
  textSizeBytes         Int
  originalFileStorageKey String?
  originalFileSha256    String?
  originalFileName      String?
  originalMimeType      String?
  originalFileSizeBytes Int?
  capturedAt            DateTime             @default(now())
  expiresAt             DateTime?
  claimedAt             DateTime?
  claimedByUserId       String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  ownerUser             User?                @relation("AnalysisCvSnapshotOwner", fields: [userId], references: [id], onDelete: SetNull)
  claimedByUser         User?                @relation("AnalysisCvSnapshotClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  cvAdaptation          CvAdaptation?

  @@index([userId])
  @@index([guestSessionHash])
  @@index([expiresAt])
  @@index([textSha256])
}

model JobSource {
  id                   String         @id @default(cuid())
  companyId            String
  sourceName           String
  sourceType           JobSourceType
  sourceUrl            String
  parserKey            String
  crawlStrategy        CrawlStrategy
  isActive             Boolean        @default(true)
  checkIntervalMinutes Int
  lastCheckedAt        DateTime?
  lastSuccessAt        DateTime?
  lastErrorAt          DateTime?
  lastErrorMessage     String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  company              Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs                 Job[]
  ingestionRuns        IngestionRun[]

  @@unique([companyId, sourceUrl])
  @@index([companyId])
}

model IngestionRun {
  id           String             @id @default(cuid())
  jobSourceId  String
  status       IngestionRunStatus @default(running)
  startedAt    DateTime           @default(now())
  finishedAt   DateTime?
  newCount     Int                @default(0)
  updatedCount Int                @default(0)
  skippedCount Int                @default(0)
  failedCount  Int                @default(0)
  errorSummary String?
  previewJson  Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  jobSource    JobSource          @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)

  @@index([jobSourceId, createdAt])
}

model AffiliatePartner {
  id        String                 @id @default(cuid())
  name      String
  slug      String                 @unique
  email     String?
  status    AffiliatePartnerStatus @default(draft)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  campaigns AffiliateCampaign[]
}

model AffiliateCampaign {
  id                     String                  @id @default(cuid())
  partnerId              String
  name                   String
  attributionWindowDays  Int                     @default(30)
  defaultCurrency        String                  @default("BRL")
  defaultDiscountType    AffiliateRewardType?
  defaultDiscountValue   Int?
  defaultCommissionType  AffiliateRewardType
  defaultCommissionValue Int
  status                 AffiliateCampaignStatus @default(draft)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  partner                AffiliatePartner        @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  codes                  AffiliateCode[]
  attributions           AffiliateAttribution[]
  commissionEvents       AffiliateCommissionEvent[]

  @@index([partnerId])
}

model AffiliateCode {
  id               String              @id @default(cuid())
  campaignId       String
  code             String              @unique
  landingPageUrl   String?
  status           AffiliateCodeStatus @default(draft)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  campaign         AffiliateCampaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attributions     AffiliateAttribution[]
  commissionEvents AffiliateCommissionEvent[]

  @@index([campaignId])
  @@unique([id, campaignId])
}

model AffiliateAttribution {
  id               String                     @id @default(cuid())
  userId           String
  affiliateCampaignId String
  affiliateCodeId  String
  attributedAt     DateTime                   @default(now())
  expiresAt        DateTime
  metadataJson     Json?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  user             User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateCampaign AffiliateCampaign         @relation(fields: [affiliateCampaignId], references: [id], onDelete: Cascade)
  affiliateCode    AffiliateCode              @relation(fields: [affiliateCodeId, affiliateCampaignId], references: [id, campaignId], onDelete: Cascade)
  commissionEvents AffiliateCommissionEvent[]

  @@index([userId])
  @@index([affiliateCampaignId])
  @@index([affiliateCodeId])
  @@index([expiresAt])
}

model AffiliateCommissionEvent {
  id                        String                    @id @default(cuid())
  userId                    String
  affiliateCampaignId       String
  affiliateCodeId           String
  affiliateAttributionId    String?
  purchaseReference         String                    @unique
  planKey                   String
  grossAmountInCents        Int
  discountAmountInCents     Int                       @default(0)
  netAmountInCents          Int
  commissionType            AffiliateRewardType
  commissionValue           Int
  commissionAmountInCents   Int
  currency                  String                    @default("BRL")
  status                    AffiliateCommissionStatus @default(pending)
  paidAt                    DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  user                      User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateCampaign         AffiliateCampaign         @relation(fields: [affiliateCampaignId], references: [id], onDelete: Cascade)
  affiliateCode             AffiliateCode             @relation(fields: [affiliateCodeId, affiliateCampaignId], references: [id, campaignId], onDelete: Cascade)
  affiliateAttribution      AffiliateAttribution?     @relation(fields: [affiliateAttributionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([affiliateCampaignId])
  @@index([affiliateCodeId])
  @@index([status])
}

model AnalysisProtectionConfig {
  id        String                  @id @default(cuid())
  key       String                  @unique
  valueJson Json
  valueType AnalysisConfigValueType
  riskLevel AnalysisConfigRiskLevel
  isActive  Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model AnalysisProtectionConfigAudit {
  id                   String                  @id @default(cuid())
  key                  String
  oldValueJson         Json?
  newValueJson         Json?
  valueType            AnalysisConfigValueType
  riskLevel            AnalysisConfigRiskLevel
  actorId              String?
  actorRole            InternalRole            @default(none)
  source               String
  technicalContextJson Json?
  changedAt            DateTime                @default(now())

  @@index([key, changedAt])
}

model AnalysisSession {
  id                     String                     @id @default(cuid())
  sessionPublicTokenHash String                     @unique
  userId                 String?
  userAgentHash          String?
  ipHash                 String?
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  lastSeenAt             DateTime                   @default(now())
  user                   User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestFingerprints    AnalysisRequestFingerprint[]
  usageCounters          AnalysisUsageCounter[]
  protectionEvents       AnalysisProtectionEvent[]
  businessFunnelEvents   BusinessFunnelEvent[]

  @@index([userId])
}

model AnalysisRequestFingerprint {
  id                String           @id @default(cuid())
  canonicalHash     String
  sessionInternalId String?
  userId            String?
  ipHash            String?
  firstSeenAt       DateTime         @default(now())
  lastSeenAt        DateTime         @default(now())
  totalCount        Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Nullable dimensions require SQL expression uniqueness in migration.
  @@index([canonicalHash])
  @@index([sessionInternalId])
  @@index([userId])
}

model AnalysisUsageCounter {
  id                String           @id @default(cuid())
  counterKey        String
  periodKey         String
  sessionInternalId String?
  userId            String?
  usedCount         Int              @default(0)
  windowStartedAt   DateTime
  windowEndsAt      DateTime
  lastUsedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Nullable dimensions require SQL expression uniqueness in migration.
  @@index([counterKey, periodKey])
  @@index([sessionInternalId])
  @@index([userId])
}

model AnalysisProtectionEvent {
  id                String           @id @default(cuid())
  eventName         String
  eventVersion      Int              @default(1)
  idempotencyKey    String?          @unique
  requestId         String
  correlationId     String
  sessionInternalId String?
  userId            String?
  routeKey          String?
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([sessionInternalId])
  @@index([userId])
}

model BusinessFunnelEvent {
  id                String           @id @default(cuid())
  eventName         String
  eventVersion      Int
  idempotencyKey    String?          @unique
  requestId         String
  correlationId     String
  sessionInternalId String?
  userId            String?
  routeKey          String?
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([sessionInternalId])
  @@index([userId])
}

model BusinessFunnelStageMetric {
  id            String   @id @default(cuid())
  stageKey      String
  metricDate    DateTime
  totalCount    Int      @default(0)
  successCount  Int      @default(0)
  errorCount    Int      @default(0)
  avgLatencyMs  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([stageKey, metricDate])
  @@index([metricDate])
}

model Job {
  id                String     @id @default(cuid())
  companyId         String
  jobSourceId       String
  externalJobId     String?
  sourceJobUrl      String
  canonicalKey      String     @unique
  title             String
  normalizedTitle   String
  descriptionRaw    String
  descriptionClean  String
  locationText      String
  city              String?
  state             String?
  country           String?
  workModel         String?
  seniorityLevel    String?
  employmentType    String?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?
  publishedAtSource DateTime?
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  status            JobStatus  @default(active)
  metadataJson      Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobSource         JobSource  @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)
  targetResumes     Resume[]

  @@index([companyId])
  @@index([jobSourceId])
  @@index([firstSeenAt])
}
