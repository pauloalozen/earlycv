generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserPlanType {
  free
  starter
  pro
  unlimited
  turbo
}

enum UserStatus {
  active
  pending
  suspended
  deleted
}

enum InternalRole {
  none
  admin
  superadmin
}

enum RemotePreference {
  remote
  hybrid
  onsite
  flexible
}

enum AuthProvider {
  credentials
  google
  linkedin
}

enum ResumeStatus {
  draft
  uploaded
  reviewed
  failed
}

enum ResumeKind {
  master
  adapted
}

enum JobSourceType {
  workday
  greenhouse
  lever
  gupy
  kenoby
  successfactors
  custom_html
  custom_api
}

enum CrawlStrategy {
  html
  api
  feed
}

enum JobStatus {
  active
  inactive
  removed
}

enum IngestionRunStatus {
  running
  completed
  failed
}

enum IngestionBatchScopeType {
  adapter
  source
  global
}

enum IngestionBatchRunStatus {
  queued
  running
  completed
  failed
  cancelling
  cancelled
}

enum IngestionBatchItemStatus {
  queued
  running
  completed
  failed
  skipped
  cancelled
}

enum AffiliatePartnerStatus {
  draft
  active
  inactive
}

enum AffiliateCampaignStatus {
  draft
  active
  inactive
}

enum AffiliateCodeStatus {
  draft
  active
  inactive
}

enum AffiliateRewardType {
  percentage
  fixed_amount
}

enum AffiliateCommissionStatus {
  pending
  approved
  paid
  reversed
}

enum CvAdaptationStatus {
  pending
  analyzing
  awaiting_payment
  paid
  delivered
  failed
}

enum CvAdaptationSource {
  uploaded_content
  user_profile
}

enum CvAdaptationInputMode {
  file_upload
  text_paste
  profile
}

enum ProfileReadinessStatus {
  empty
  partial
  ready
}

enum MasterCvCanonicalExtractionStatus {
  pending
  processing
  succeeded
  failed
}

enum AnalysisJobStatus {
  pending
  processing
  succeeded
  failed
}

enum AnalysisJobOwnerKind {
  guest
  authenticated
}

enum PaymentStatus {
  none
  pending
  processing_payment
  pending_payment
  completed
  failed
  refunded
}

enum PaymentProvider {
  mercadopago
  stripe
}

enum PaymentRecoveryEligibilityStatus {
  eligible
  possibly_resolved
  not_eligible
}

enum PaymentRecoveryEmailStatus {
  sent
  failed
  skipped
}

enum PlanPurchaseOriginAction {
  buy_credits
  unlock_cv
}

enum CvUnlockSource {
  CREDIT
  ADMIN
  PLAN_ENTITLEMENT
  LEGACY
}

enum CvUnlockStatus {
  UNLOCKED
  REVOKED
}

enum AnalysisCvSourceType {
  text_input
  uploaded_file
  master_resume
  user_profile
}

enum AnalysisConfigValueType {
  boolean
  int
  duration_ms
  percent
  string
  enum
  json
}

enum JobApplicationStatus {
  SAVED
  ANALYZED
  CV_READY
  APPLIED
  IN_PROCESS
  INTERVIEW
  ASSESSMENT
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
}

enum JobApplicationOrigin {
  analysis_auto
  optimized_cv_auto
  manual
  imported_url
  job_portal
}

enum JobApplicationEventType {
  APPLICATION_CREATED
  ANALYSIS_COMPLETED
  CV_READY
  STATUS_CHANGED
  NOTE_ADDED
  MARKED_AS_SENT
  INTERVIEW_PREP_GENERATED
}

enum AnalysisConfigRiskLevel {
  low
  medium
  high
}

model User {
  id                           String                        @id @default(cuid())
  email                        String                        @unique
  passwordHash                 String?
  name                         String
  planType                     UserPlanType                  @default(free)
  creditsRemaining             Int                           @default(0)
  analysisCreditsRemaining     Int                           @default(0)
  planActivatedAt              DateTime?
  planExpiresAt                DateTime?
  status                       UserStatus                    @default(pending)
  internalRole                 InternalRole                  @default(none)
  isStaff                      Boolean                       @default(false)
  emailVerifiedAt              DateTime?
  lastLoginAt                  DateTime?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  profile                      UserProfile?
  authAccounts                 AuthAccount[]
  refreshTokens                RefreshToken[]
  emailVerificationChallenges  EmailVerificationChallenge[]
  passwordResetTokens          PasswordResetToken[]
  resumes                      Resume[]
  cvAdaptations                CvAdaptation[]
  cvUnlocks                    CvUnlock[]
  planPurchases                PlanPurchase[]
  dailyAnalysisUsages          UserDailyAnalysisUsage[]
  affiliateAttributions        AffiliateAttribution[]
  affiliateCommissionEvents    AffiliateCommissionEvent[]
  analysisSessions             AnalysisSession[]
  analysisRequestFingerprints  AnalysisRequestFingerprint[]
  analysisUsageCounters        AnalysisUsageCounter[]
  analysisProtectionEvents     AnalysisProtectionEvent[]
  businessFunnelEvents         BusinessFunnelEvent[]
  analysisCvSnapshots          AnalysisCvSnapshot[]          @relation("AnalysisCvSnapshotOwner")
  claimedAnalysisCvSnapshots   AnalysisCvSnapshot[]          @relation("AnalysisCvSnapshotClaimedBy")
  requestedIngestionBatchRuns  IngestionBatchRun[]           @relation("IngestionBatchRunRequestedByUser")
  jobApplications              JobApplication[]
  masterCvCanonicalExtractions MasterCvCanonicalExtraction[]
  analysisJobs                 AnalysisJob[]
}

model UserDailyAnalysisUsage {
  id        String   @id @default(cuid())
  userId    String
  usageDate DateTime
  usedCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@index([usageDate])
}

model PlanPurchase {
  id                     String                   @id @default(cuid())
  userId                 String
  planType               UserPlanType
  amountInCents          Int
  currency               String                   @default("BRL")
  paymentProvider        PaymentProvider
  paymentReference       String                   @unique
  status                 PaymentStatus            @default(none)
  paidAt                 DateTime?
  creditsGranted         Int
  analysisCreditsGranted Int                      @default(0)
  mpPaymentId            String?
  mpMerchantOrderId      String?
  mpPreferenceId         String?
  originAction           PlanPurchaseOriginAction @default(buy_credits)
  originAdaptationId     String?
  autoUnlockProcessedAt  DateTime?
  autoUnlockError        String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([originAdaptationId])
  @@index([paymentReference])
  @@index([mpPaymentId])
}

model PaymentRecoveryEmail {
  id                String                     @id @default(cuid())
  purchaseId        String
  userId            String
  adaptationId      String?
  recoveryGroupKey  String
  step              String                     @default("manual_admin")
  status            PaymentRecoveryEmailStatus
  sentByAdminUserId String
  sentAt            DateTime?
  dryRun            Boolean                    @default(true)
  allowlistMatched  Boolean                    @default(false)
  realEmailSent     Boolean                    @default(false)
  providerMessageId String?
  errorMessage      String?
  subject           String?
  preheader         String?
  templateVariables Json?
  tokenId           String?                    @unique
  clickedAt         DateTime?
  metadataJson      Json?
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  token PaymentRecoveryToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@index([purchaseId, createdAt])
  @@index([userId, createdAt])
  @@index([adaptationId])
  @@index([recoveryGroupKey, createdAt])
}

model PaymentRecoveryToken {
  id               String    @id @default(cuid())
  purchaseId       String
  userId           String
  adaptationId     String?
  recoveryGroupKey String
  tokenHash        String    @unique
  emailRecordId    String?   @unique
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  emailRecord PaymentRecoveryEmail?

  @@index([purchaseId, createdAt])
  @@index([userId, createdAt])
  @@index([expiresAt])
  @@index([recoveryGroupKey, createdAt])
}

model PaymentRecoveryIgnore {
  id               String   @id @default(cuid())
  purchaseId       String   @unique
  userId           String
  adaptationId     String?
  reason           String?
  ignoredByAdminId String
  ignoredAt        DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([adaptationId])
  @@index([ignoredAt])
}

model PaymentAuditLog {
  id                   String   @id @default(cuid())
  provider             String
  eventType            String
  actionTaken          String
  mpPaymentId          String?
  mpMerchantOrderId    String?
  mpPreferenceId       String?
  externalReference    String?
  internalCheckoutId   String?
  internalCheckoutType String?
  mpStatus             String?
  errorMessage         String?
  rawPayload           Json?
  createdAt            DateTime @default(now())

  @@index([mpPaymentId])
  @@index([externalReference])
  @@index([internalCheckoutId])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationChallenge {
  id         String    @id @default(cuid())
  userId     String
  codeHash   String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, consumedAt, expiresAt])
}

model UserProfile {
  id                     String                 @id @default(cuid())
  userId                 String                 @unique
  fullName               String?
  contactEmail           String?
  phone                  String?
  linkedinUrl            String?
  professionalSummary    String?
  headline               String?
  currentTitle           String?
  summary                String?
  yearsExperience        Int?
  city                   String?
  state                  String?
  country                String?
  remotePreference       RemotePreference?
  relocationPreference   Boolean?
  targetSalaryMin        Int?
  targetSalaryMax        Int?
  preferredLanguage      String?
  experiencesJson        Json?
  educationJson          Json?
  skillsJson             Json?
  languagesJson          Json?
  certificationsJson     Json?
  profileFieldMetaJson   Json?
  profileSuggestionsJson Json?
  profileReadinessStatus ProfileReadinessStatus @default(empty)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  user                   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthAccount {
  id                    String       @id @default(cuid())
  userId                String
  provider              AuthProvider
  providerAccountId     String
  providerEmail         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  sessionId String    @unique
  tokenHash String
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Resume {
  id                           String                        @id @default(cuid())
  userId                       String
  title                        String
  sourceFileName               String?
  sourceFileUrl                String?
  sourceFileType               String?
  rawText                      String?
  parsedJson                   Json?
  normalizedJson               Json?
  status                       ResumeStatus                  @default(draft)
  kind                         ResumeKind                    @default(master)
  isMaster                     Boolean                       @default(true)
  basedOnResumeId              String?
  templateId                   String?
  targetJobId                  String?
  targetJobTitle               String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  user                         User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  basedOnResume                Resume?                       @relation("ResumeDerivation", fields: [basedOnResumeId], references: [id], onDelete: SetNull)
  derivedResumes               Resume[]                      @relation("ResumeDerivation")
  template                     ResumeTemplate?               @relation(fields: [templateId], references: [id], onDelete: SetNull)
  targetJob                    Job?                          @relation(fields: [targetJobId], references: [id], onDelete: SetNull)
  cvAdaptationsAsMaster        CvAdaptation[]                @relation("CvAdaptationMaster")
  cvAdaptationAsResult         CvAdaptation?                 @relation("CvAdaptationResult")
  masterCvCanonicalExtractions MasterCvCanonicalExtraction[]

  @@index([userId])
  @@index([basedOnResumeId])
  @@index([templateId])
  @@index([targetJobId])
}

model CanonicalJob {
  id                            String              @id @default(cuid())
  canonicalJobHash              String              @unique
  requirementSourceHash         String
  canonicalJobJson              Json
  canonicalizationModel         String
  canonicalizationPromptVersion String
  createdAt                     DateTime            @default(now())
  updatedAt                     DateTime            @updatedAt
  rawInputs                     JobRawInput[]
  cvAdaptations                 CvAdaptation[]
  jobRequirementSets            JobRequirementSet[]

  @@index([requirementSourceHash])
}

model JobRequirementSet {
  id                    String   @id @default(cuid())
  requirementSourceHash String   @unique
  canonicalJobId        String
  requirementsJson      Json
  analysisModel         String
  analysisPromptVersion String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  canonicalJob  CanonicalJob   @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)
  cvAdaptations CvAdaptation[]

  @@index([canonicalJobId])
}

model JobRawInput {
  id                String   @id @default(cuid())
  rawJobHash        String   @unique
  rawText           String   @db.Text
  normalizedRawText String   @db.Text
  canonicalJobId    String
  createdAt         DateTime @default(now())

  canonicalJob CanonicalJob @relation(fields: [canonicalJobId], references: [id], onDelete: Cascade)

  @@index([canonicalJobId, createdAt])
}

model MasterCvCanonicalExtraction {
  id             String                            @id @default(cuid())
  userId         String
  resumeId       String
  inputHash      String
  status         MasterCvCanonicalExtractionStatus @default(pending)
  attempts       Int                               @default(0)
  lastError      String?
  canonicalJson  Json?
  coverageJson   Json?
  confidenceJson Json?
  evidenceJson   Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime                          @default(now())
  updatedAt      DateTime                          @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@unique([resumeId, inputHash])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, updatedAt])
}

model ResumeTemplate {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique
  description     String?
  targetRole      String?
  fileUrl         String?
  previewImageUrl String?
  structureJson   Json?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  resumes         Resume[]
  cvAdaptations   CvAdaptation[]
}

model Company {
  id                  String               @id @default(cuid())
  name                String
  normalizedName      String               @unique
  websiteUrl          String?
  careersUrl          String?
  linkedinUrl         String?
  industry            String?
  country             String?
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  jobSources          JobSource[]
  jobs                Job[]
  ingestionBatchItems IngestionBatchItem[]
}

model CvAdaptation {
  id                          String                @id @default(cuid())
  userId                      String
  masterResumeId              String?
  templateId                  String?
  canonicalJobId              String?
  jobRequirementSetId         String?
  adaptationSource            CvAdaptationSource    @default(uploaded_content)
  inputMode                   CvAdaptationInputMode @default(file_upload)
  jobDescriptionText          String
  jobTitle                    String?
  companyName                 String?
  status                      CvAdaptationStatus    @default(pending)
  adaptedContentJson          Json?
  previewText                 String?
  adaptedResumeId             String?               @unique
  aiAuditJson                 Json?
  editedCvJson                Json?
  paymentStatus               PaymentStatus         @default(none)
  paymentProvider             PaymentProvider?
  paymentReference            String?               @unique
  paymentAmountInCents        Int?
  paymentCurrency             String?               @default("BRL")
  paidAt                      DateTime?
  mpPaymentId                 String?
  mpMerchantOrderId           String?
  mpPreferenceId              String?
  failureReason               String?
  isUnlocked                  Boolean               @default(false)
  unlockedAt                  DateTime?
  analysisCvSnapshotId        String?               @unique
  userProfileSnapshotJson     Json?
  uploadedContentSnapshotJson Json?
  analysisInputSnapshotJson   Json?
  generationInputSnapshotJson Json?
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  jobApplicationId String?

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Não usar Cascade: o CV master é editável/substituível a qualquer momento
  // (ver apps/api/src/resumes/resumes.service.ts) e a análise deve
  // sobreviver independente dele — o conteúdo real do CV usado na análise
  // fica em analysisCvSnapshot, não neste ponteiro. masterResumeId é só
  // referência informativa; perdê-la (SetNull) não perde a análise.
  masterResume       Resume?             @relation("CvAdaptationMaster", fields: [masterResumeId], references: [id], onDelete: SetNull)
  template           ResumeTemplate?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  canonicalJob       CanonicalJob?       @relation(fields: [canonicalJobId], references: [id], onDelete: SetNull)
  jobRequirementSet  JobRequirementSet?  @relation(fields: [jobRequirementSetId], references: [id], onDelete: SetNull)
  adaptedResume      Resume?             @relation("CvAdaptationResult", fields: [adaptedResumeId], references: [id], onDelete: SetNull)
  analysisCvSnapshot AnalysisCvSnapshot? @relation(fields: [analysisCvSnapshotId], references: [id], onDelete: SetNull)
  cvUnlock           CvUnlock?
  jobApplication     JobApplication?     @relation(fields: [jobApplicationId], references: [id], onDelete: SetNull)
  originAnalysisJob  AnalysisJob?

  @@index([userId, createdAt])
  @@index([masterResumeId])
  @@index([paymentReference])
  @@index([mpPaymentId])
  @@index([analysisCvSnapshotId])
  @@index([jobApplicationId])
  @@index([canonicalJobId])
}

model CvUnlock {
  id              String         @id @default(cuid())
  userId          String
  cvAdaptationId  String         @unique
  creditsConsumed Int            @default(1)
  source          CvUnlockSource @default(CREDIT)
  status          CvUnlockStatus @default(UNLOCKED)
  unlockedAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvAdaptation CvAdaptation @relation(fields: [cvAdaptationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([cvAdaptationId])
  @@index([unlockedAt])
  @@index([source])
  @@index([status])
}

model AnalysisCvSnapshot {
  id                             String               @id @default(cuid())
  userId                         String?
  guestSessionHash               String?
  sourceType                     AnalysisCvSourceType
  textStorageKey                 String
  textSha256                     String
  textSizeBytes                  Int
  originalFileStorageKey         String?
  originalFileSha256             String?
  originalFileName               String?
  originalMimeType               String?
  originalFileSizeBytes          Int?
  professionalProfileFingerprint String
  professionalProfileJson        Json
  capturedAt                     DateTime             @default(now())
  expiresAt                      DateTime?
  claimedAt                      DateTime?
  claimedByUserId                String?
  createdAt                      DateTime             @default(now())
  updatedAt                      DateTime             @updatedAt

  ownerUser     User?         @relation("AnalysisCvSnapshotOwner", fields: [userId], references: [id], onDelete: SetNull)
  claimedByUser User?         @relation("AnalysisCvSnapshotClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  cvAdaptation  CvAdaptation?
  analysisJob   AnalysisJob?

  @@index([userId])
  @@index([guestSessionHash])
  @@index([expiresAt])
  @@index([textSha256])
  @@index([professionalProfileFingerprint])
}

// Assíncrono desde a criação (item 3 do plano de LLM síncronas → assíncronas):
// canonicalização da vaga + análise rodam em background, o cliente (guest ou
// autenticado) faz polling nesta linha até status "succeeded"/"failed".
//
// Também é o registro permanente de retenção/analytics decidido em
// 2026-07-18: toda análise feita (guest ou logada) fica guardada aqui pra
// sempre, mesmo que a pessoa nunca converta — hoje esse dado era gerado e
// jogado fora. convertedAt/convertedCvAdaptationId marcam quando (e se) virou
// conta de verdade, sem depender de nenhum token novo: a correlação usa o
// mesmo analysisCvSnapshotId que já flui pela jornada do guest hoje
// (sessionStorage do navegador → saveGuestPreview/claimGuest →
// validateAndClaimSnapshot).
model AnalysisJob {
  id                      String               @id @default(cuid())
  ownerKind               AnalysisJobOwnerKind
  status                  AnalysisJobStatus    @default(pending)
  userId                  String?
  guestSessionHash        String?
  jobDescriptionText      String
  masterCvText            String?
  jobTitle                String?
  companyName             String?
  adaptedContentJson      Json?
  previewText             String?
  scoreBefore             Int?
  scoreAfter              Int?
  analysisCvSnapshotId    String?              @unique
  lastError               String?
  convertedAt             DateTime?
  convertedCvAdaptationId String?              @unique
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  startedAt               DateTime?
  finishedAt              DateTime?

  user                  User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  analysisCvSnapshot    AnalysisCvSnapshot? @relation(fields: [analysisCvSnapshotId], references: [id], onDelete: SetNull)
  convertedCvAdaptation CvAdaptation?       @relation(fields: [convertedCvAdaptationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([guestSessionHash])
  @@index([status])
  @@index([createdAt])
  @@index([convertedAt])
}

model JobSource {
  id                   String               @id @default(cuid())
  companyId            String
  sourceName           String
  sourceType           JobSourceType
  sourceUrl            String
  parserKey            String
  crawlStrategy        CrawlStrategy
  isActive             Boolean              @default(true)
  scheduleEnabled      Boolean              @default(false)
  scheduleCron         String?
  scheduleTimezone     String               @default("America/Sao_Paulo")
  isFallbackAdapter    Boolean              @default(false)
  checkIntervalMinutes Int
  lastCheckedAt        DateTime?
  lastSuccessAt        DateTime?
  lastErrorAt          DateTime?
  lastErrorMessage     String?
  consecutive403Count  Int                  @default(0)
  pausedUntil          DateTime?
  pauseReason          String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  company              Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobs                 Job[]
  ingestionRuns        IngestionRun[]
  ingestionBatchItems  IngestionBatchItem[]

  @@unique([companyId, sourceUrl])
  @@index([companyId])
}

model IngestionSchedulerConfig {
  id            String   @id
  enabled       Boolean  @default(false)
  globalCron    String?
  timezone      String   @default("America/Sao_Paulo")
  normalDelayMs Int      @default(45000)
  errorDelayMs  Int      @default(90000)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IngestionSchedulerLock {
  id        String   @id
  owner     String
  lockedAt  DateTime
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IngestionRun {
  id                  String               @id @default(cuid())
  jobSourceId         String
  status              IngestionRunStatus   @default(running)
  startedAt           DateTime             @default(now())
  finishedAt          DateTime?
  newCount            Int                  @default(0)
  updatedCount        Int                  @default(0)
  skippedCount        Int                  @default(0)
  failedCount         Int                  @default(0)
  errorSummary        String?
  previewJson         Json?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  jobSource           JobSource            @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)
  ingestionBatchItems IngestionBatchItem[]

  @@index([jobSourceId, createdAt])
}

model IngestionBatchRun {
  id                String                  @id @default(cuid())
  scopeType         IngestionBatchScopeType
  scopeValue        String
  status            IngestionBatchRunStatus @default(queued)
  requestedByUserId String?
  startedAt         DateTime?
  finishedAt        DateTime?
  cancelRequestedAt DateTime?
  totalSources      Int                     @default(0)
  succeededCount    Int                     @default(0)
  failedCount       Int                     @default(0)
  skippedCount      Int                     @default(0)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  requestedByUser   User?                   @relation("IngestionBatchRunRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  items             IngestionBatchItem[]

  @@index([status, createdAt])
  @@index([scopeType, scopeValue, createdAt])
  @@index([requestedByUserId, createdAt])
}

model IngestionBatchItem {
  id             String                   @id @default(cuid())
  batchRunId     String
  jobSourceId    String
  companyId      String
  companyName    String
  sourceName     String
  sourceType     JobSourceType
  status         IngestionBatchItemStatus @default(queued)
  startedAt      DateTime?
  finishedAt     DateTime?
  errorMessage   String?
  ingestionRunId String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  batchRun       IngestionBatchRun        @relation(fields: [batchRunId], references: [id], onDelete: Cascade)
  jobSource      JobSource                @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)
  company        Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ingestionRun   IngestionRun?            @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([batchRunId, jobSourceId])
  @@index([batchRunId, status, createdAt])
  @@index([status, updatedAt])
  @@index([jobSourceId])
  @@index([companyId])
  @@index([ingestionRunId])
}

model AffiliatePartner {
  id        String                 @id @default(cuid())
  name      String
  slug      String                 @unique
  email     String?
  status    AffiliatePartnerStatus @default(draft)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  campaigns AffiliateCampaign[]
}

model AffiliateCampaign {
  id                     String                     @id @default(cuid())
  partnerId              String
  name                   String
  attributionWindowDays  Int                        @default(30)
  defaultCurrency        String                     @default("BRL")
  defaultDiscountType    AffiliateRewardType?
  defaultDiscountValue   Int?
  defaultCommissionType  AffiliateRewardType
  defaultCommissionValue Int
  status                 AffiliateCampaignStatus    @default(draft)
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
  partner                AffiliatePartner           @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  codes                  AffiliateCode[]
  attributions           AffiliateAttribution[]
  commissionEvents       AffiliateCommissionEvent[]

  @@index([partnerId])
}

model AffiliateCode {
  id               String                     @id @default(cuid())
  campaignId       String
  code             String                     @unique
  landingPageUrl   String?
  status           AffiliateCodeStatus        @default(draft)
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt
  campaign         AffiliateCampaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  attributions     AffiliateAttribution[]
  commissionEvents AffiliateCommissionEvent[]

  @@unique([id, campaignId])
  @@index([campaignId])
}

model AffiliateAttribution {
  id                  String                     @id @default(cuid())
  userId              String
  affiliateCampaignId String
  affiliateCodeId     String
  attributedAt        DateTime                   @default(now())
  expiresAt           DateTime
  metadataJson        Json?
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateCampaign   AffiliateCampaign          @relation(fields: [affiliateCampaignId], references: [id], onDelete: Cascade)
  affiliateCode       AffiliateCode              @relation(fields: [affiliateCodeId, affiliateCampaignId], references: [id, campaignId], onDelete: Cascade)
  commissionEvents    AffiliateCommissionEvent[]

  @@index([userId])
  @@index([affiliateCampaignId])
  @@index([affiliateCodeId])
  @@index([expiresAt])
}

model AffiliateCommissionEvent {
  id                      String                    @id @default(cuid())
  userId                  String
  affiliateCampaignId     String
  affiliateCodeId         String
  affiliateAttributionId  String?
  purchaseReference       String                    @unique
  planKey                 String
  grossAmountInCents      Int
  discountAmountInCents   Int                       @default(0)
  netAmountInCents        Int
  commissionType          AffiliateRewardType
  commissionValue         Int
  commissionAmountInCents Int
  currency                String                    @default("BRL")
  status                  AffiliateCommissionStatus @default(pending)
  paidAt                  DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  user                    User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  affiliateCampaign       AffiliateCampaign         @relation(fields: [affiliateCampaignId], references: [id], onDelete: Cascade)
  affiliateCode           AffiliateCode             @relation(fields: [affiliateCodeId, affiliateCampaignId], references: [id, campaignId], onDelete: Cascade)
  affiliateAttribution    AffiliateAttribution?     @relation(fields: [affiliateAttributionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([affiliateCampaignId])
  @@index([affiliateCodeId])
  @@index([status])
}

model AnalysisProtectionConfig {
  id        String                  @id @default(cuid())
  key       String                  @unique
  valueJson Json
  valueType AnalysisConfigValueType
  riskLevel AnalysisConfigRiskLevel
  isActive  Boolean                 @default(true)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
}

model AnalysisProtectionConfigAudit {
  id                   String                  @id @default(cuid())
  key                  String
  oldValueJson         Json?
  newValueJson         Json?
  valueType            AnalysisConfigValueType
  riskLevel            AnalysisConfigRiskLevel
  actorId              String?
  actorRole            InternalRole            @default(none)
  source               String
  technicalContextJson Json?
  changedAt            DateTime                @default(now())

  @@index([key, changedAt])
}

model AnalysisSession {
  id                     String                       @id @default(cuid())
  sessionPublicTokenHash String                       @unique
  userId                 String?
  userAgentHash          String?
  ipHash                 String?
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  lastSeenAt             DateTime                     @default(now())
  user                   User?                        @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestFingerprints    AnalysisRequestFingerprint[]
  usageCounters          AnalysisUsageCounter[]
  protectionEvents       AnalysisProtectionEvent[]
  businessFunnelEvents   BusinessFunnelEvent[]

  @@index([userId])
}

model AnalysisRequestFingerprint {
  id                String           @id @default(cuid())
  canonicalHash     String
  sessionInternalId String?
  userId            String?
  ipHash            String?
  firstSeenAt       DateTime         @default(now())
  lastSeenAt        DateTime         @default(now())
  totalCount        Int              @default(1)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Nullable dimensions require SQL expression uniqueness in migration.
  @@index([canonicalHash])
  @@index([sessionInternalId])
  @@index([userId])
}

model AnalysisUsageCounter {
  id                String           @id @default(cuid())
  counterKey        String
  periodKey         String
  sessionInternalId String?
  userId            String?
  usedCount         Int              @default(0)
  windowStartedAt   DateTime
  windowEndsAt      DateTime
  lastUsedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Nullable dimensions require SQL expression uniqueness in migration.
  @@index([counterKey, periodKey])
  @@index([sessionInternalId])
  @@index([userId])
}

model AnalysisProtectionEvent {
  id                String           @id @default(cuid())
  eventName         String
  eventVersion      Int              @default(1)
  idempotencyKey    String?          @unique
  requestId         String
  correlationId     String
  sessionInternalId String?
  userId            String?
  routeKey          String?
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([sessionInternalId])
  @@index([userId])
}

model BusinessFunnelEvent {
  id                String           @id @default(cuid())
  eventName         String
  eventVersion      Int
  idempotencyKey    String?          @unique
  requestId         String
  correlationId     String
  sessionInternalId String?
  userId            String?
  routeKey          String?
  metadataJson      Json?
  createdAt         DateTime         @default(now())
  session           AnalysisSession? @relation(fields: [sessionInternalId], references: [id], onDelete: SetNull)
  user              User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventName, createdAt])
  @@index([requestId])
  @@index([correlationId])
  @@index([sessionInternalId])
  @@index([userId])
}

model BusinessFunnelStageMetric {
  id           String   @id @default(cuid())
  stageKey     String
  metricDate   DateTime
  totalCount   Int      @default(0)
  successCount Int      @default(0)
  errorCount   Int      @default(0)
  avgLatencyMs Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([stageKey, metricDate])
  @@index([metricDate])
}

model Job {
  id                String    @id @default(cuid())
  companyId         String
  jobSourceId       String
  externalJobId     String?
  sourceJobUrl      String
  canonicalKey      String    @unique
  title             String
  normalizedTitle   String
  descriptionRaw    String
  descriptionClean  String
  locationText      String
  city              String?
  state             String?
  country           String?
  workModel         String?
  seniorityLevel    String?
  employmentType    String?
  salaryMin         Int?
  salaryMax         Int?
  salaryCurrency    String?
  publishedAtSource DateTime?
  firstSeenAt       DateTime
  lastSeenAt        DateTime
  status            JobStatus @default(active)
  metadataJson      Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobSource         JobSource @relation(fields: [jobSourceId], references: [id], onDelete: Cascade)
  targetResumes     Resume[]

  @@index([companyId])
  @@index([jobSourceId])
  @@index([firstSeenAt])
}

model JobApplication {
  id                    String               @id @default(cuid())
  userId                String
  jobTitle              String
  companyName           String
  normalizedJobTitle    String
  normalizedCompanyName String
  location              String?
  jobUrl                String?
  jobDescriptionText    String?
  status                JobApplicationStatus @default(ANALYZED)
  origin                JobApplicationOrigin @default(analysis_auto)
  currentCvAdaptationId String?
  scoreBefore           Int?
  scoreAfter            Int?
  notes                 String?
  appliedAt             DateTime?
  nextActionAt          DateTime?
  interviewTitle        String?
  interviewerName       String?
  interviewMeetingUrl   String?
  interviewLocation     String?
  rejectionStrengths    String?
  rejectionImprovements String?
  archivedAt            DateTime?
  deletedAt             DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  user          User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvAdaptations CvAdaptation[]
  events        JobApplicationEvent[]
  interviewPrep JobApplicationInterviewPrep?

  @@index([userId, createdAt])
  @@index([userId, status])
  @@index([userId, normalizedCompanyName, normalizedJobTitle])
}

model JobApplicationEvent {
  id               String                  @id @default(cuid())
  jobApplicationId String
  eventType        JobApplicationEventType
  previousStatus   JobApplicationStatus?
  newStatus        JobApplicationStatus?
  metadata         Json?
  createdAt        DateTime                @default(now())

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)

  @@index([jobApplicationId, createdAt])
}

enum InterviewPrepStatus {
  pending
  processing
  succeeded
  failed
}

model JobApplicationInterviewPrep {
  id                   String              @id @default(cuid())
  jobApplicationId     String              @unique
  status               InterviewPrepStatus @default(pending)
  generatedContentJson Json?
  lastError            String?
  generatedAt          DateTime?
  startedAt            DateTime?
  finishedAt           DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  jobApplication JobApplication @relation(fields: [jobApplicationId], references: [id], onDelete: Cascade)
}
